{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:arxiv.org)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(python:*)",
      "mcp__mem-mesh__session_resume",
      "mcp__mem-mesh__stats",
      "mcp__mem-mesh__batch_operations"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mem-mesh-track.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/mem-mesh-stop.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
