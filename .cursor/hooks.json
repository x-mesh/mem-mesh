{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".cursor/hooks/mem-mesh-session-start.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "sessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".cursor/hooks/mem-mesh-session-end.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".cursor/hooks/mem-mesh-auto-save.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
