{
  "enabled": true,
  "name": "Manual Save to mem-mesh",
  "description": "현재 대화를 수동으로 mem-mesh에 저장",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "현재 대화 전체를 mem-mesh에 저장해주세요:\n- 대화의 주요 내용을 요약\n- 적절한 카테고리 선택 (task/bug/idea/decision/incident/code_snippet)\n- 관련 태그 추가\n- 프로젝트 ID: {{projectName}}"
  },
  "workspaceFolderName": "mem-mesh",
  "shortName": "manual-save-memmesh"
}