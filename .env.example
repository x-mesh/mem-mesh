# mem-mesh 환경 설정 예시
# 이 파일을 .env로 복사하고 필요에 따라 수정하세요

# 🆕 새로운 아키텍처 설정 (v2.0)
# 스토리지 모드: direct (기본값) 또는 api
MEM_MESH_STORAGE_MODE=direct

# API 모드 설정 (storage_mode=api일 때만 사용)
MEM_MESH_API_BASE_URL=http://localhost:8000

# SQLite 설정
MEM_MESH_BUSY_TIMEOUT=5000

# 데이터베이스 설정
MEM_MESH_DATABASE_PATH=./data/memories.db

# 로깅 설정
MEM_MESH_LOG_LEVEL=INFO

# MCP 로깅 설정 (파일 로깅 활성화)
# MCP_LOG_LEVEL=INFO
# MCP_LOG_FILE=./logs/mem-mesh.log
# MCP_LOG_FORMAT=text
# MCP_LOG_OUTPUT=console

# 메모리 내용 길이 제한
MEM_MESH_MIN_CONTENT_LENGTH=10
MEM_MESH_MAX_CONTENT_LENGTH=10000

# 임베딩 모델 설정
MEM_MESH_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEM_MESH_EMBEDDING_DIM=384

# 검색 설정
MEM_MESH_SEARCH_THRESHOLD=0.5

# UnifiedSearchService 설정 (검색 품질 개선)
MEM_MESH_USE_UNIFIED_SEARCH=true
MEM_MESH_ENABLE_QUALITY_FEATURES=true
MEM_MESH_ENABLE_KOREAN_OPTIMIZATION=true
MEM_MESH_ENABLE_NOISE_FILTER=true
MEM_MESH_ENABLE_SEARCH_CACHE=true
MEM_MESH_ENABLE_SCORE_NORMALIZATION=true
MEM_MESH_SCORE_NORMALIZATION_METHOD=sigmoid
MEM_MESH_ENABLE_SEARCH_WARMUP=true

# 캐시 TTL 설정 (초 단위)
MEM_MESH_CACHE_EMBEDDING_TTL=86400  # 24시간 (임베딩은 안정적)
MEM_MESH_CACHE_SEARCH_TTL=3600      # 1시간 (검색 결과는 자주 변경)
MEM_MESH_CACHE_CONTEXT_TTL=1800     # 30분 (컨텍스트는 동적)

# 서버 설정 (선택사항)
MEM_MESH_SERVER_HOST=127.0.0.1
MEM_MESH_SERVER_PORT=8000
MEM_MESH_SERVER_WORKERS=1

# API 클라이언트 설정
MEM_MESH_API_TIMEOUT=30.0
MEM_MESH_API_MAX_RETRIES=3

# 임베딩 재시도 설정
MEM_MESH_MAX_EMBEDDING_RETRIES=3
MEM_MESH_EMBEDDING_RETRY_DELAY=0.1

# MCP_LOG_LEVEL=DEBUG
# MCP_LOG_FILE=./logs/mem-mesh.log
# MCP_LOG_FORMAT=text

MEM_MESH_LOG_LEVEL=DEBUG
MEM_MESH_LOG_FILE=./logs/mem-mesh.log
MEM_MESH_LOG_FORMAT=text
MEM_MESH_LOG_OUTPUT=file



# OAuth 2.1 인증 설정
# 전역 인증 활성화 (MCP + Web API 모두)
# MEM_MESH_AUTH_ENABLED=false

# MCP SSE 인증만 활성화 (auth_enabled보다 우선)
# MEM_MESH_MCP_AUTH_ENABLED=false

# Web Dashboard API 인증만 활성화 (auth_enabled보다 우선)
# MEM_MESH_WEB_AUTH_ENABLED=false

# Basic Auth for Web Dashboard (브라우저 로그인)
# MEM_MESH_WEB_BASIC_AUTH_ENABLED=false
# MEM_MESH_ADMIN_USERNAME=admin
# MEM_MESH_ADMIN_PASSWORD=your-secure-password

# OAuth 발급자 URL (기본값: http://localhost:8000)
# MEM_MESH_OAUTH_ISSUER=http://localhost:8000

# 토큰 만료 시간 설정 (초 단위)
# MEM_MESH_ACCESS_TOKEN_TTL=3600      # 1시간
# MEM_MESH_REFRESH_TOKEN_TTL=604800   # 7일

# 프로덕션 설정 예시 (선택사항)
# MEM_MESH_STORAGE_MODE=direct
# MEM_MESH_DATABASE_PATH=/var/lib/mem-mesh/memories.db
# MEM_MESH_LOG_LEVEL=WARNING
# MEM_MESH_SEARCH_THRESHOLD=0.7
# MEM_MESH_BUSY_TIMEOUT=10000