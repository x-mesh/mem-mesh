# mem-mesh Environment Configuration
# Copy this file to .env and modify as needed

# Storage mode: direct (default) or api
MEM_MESH_STORAGE_MODE=direct

# API mode settings (only used when storage_mode=api)
MEM_MESH_API_BASE_URL=http://localhost:8000

# SQLite settings
MEM_MESH_BUSY_TIMEOUT=5000

# Database settings
MEM_MESH_DATABASE_PATH=./data/memories.db

# Logging
MEM_MESH_LOG_LEVEL=INFO

# Memory content length limits
MEM_MESH_MIN_CONTENT_LENGTH=10
MEM_MESH_MAX_CONTENT_LENGTH=10000

# Embedding model settings (defaults to nlpai-lab/KURE-v1, 1024-dim).
# Uncomment only if you want to override. Changing this after memories exist
# requires re-embedding (POST /api/embeddings/migrate).
# MEM_MESH_EMBEDDING_MODEL=nlpai-lab/KURE-v1
# MEM_MESH_EMBEDDING_DIM=1024

# Search settings
MEM_MESH_SEARCH_THRESHOLD=0.5

# UnifiedSearchService settings (search quality)
MEM_MESH_USE_UNIFIED_SEARCH=true
MEM_MESH_ENABLE_QUALITY_FEATURES=true
MEM_MESH_ENABLE_KOREAN_OPTIMIZATION=true
MEM_MESH_ENABLE_NOISE_FILTER=true
MEM_MESH_ENABLE_SEARCH_CACHE=true
MEM_MESH_ENABLE_SCORE_NORMALIZATION=true
MEM_MESH_SCORE_NORMALIZATION_METHOD=sigmoid
MEM_MESH_ENABLE_SEARCH_WARMUP=true

# Cache TTL settings (seconds)
MEM_MESH_CACHE_EMBEDDING_TTL=86400   # 24h (embeddings are stable)
MEM_MESH_CACHE_SEARCH_TTL=3600       # 1h (search results change frequently)
MEM_MESH_CACHE_CONTEXT_TTL=1800      # 30min (context is dynamic)

# Server settings (optional)
MEM_MESH_SERVER_HOST=127.0.0.1
MEM_MESH_SERVER_PORT=8000
MEM_MESH_SERVER_WORKERS=1

# API client settings
MEM_MESH_API_TIMEOUT=30.0
MEM_MESH_API_MAX_RETRIES=3

# Embedding retry settings
MEM_MESH_MAX_EMBEDDING_RETRIES=3
MEM_MESH_EMBEDDING_RETRY_DELAY=0.1

# Unified logging settings
MEM_MESH_LOG_LEVEL=DEBUG
MEM_MESH_LOG_FILE=./logs/mem-mesh.log
MEM_MESH_LOG_FORMAT=text
MEM_MESH_LOG_OUTPUT=file

# CORS settings
# In production, only allow specific origins
# MEM_MESH_CORS_ORIGINS=https://your-domain.com,https://api.your-domain.com
MEM_MESH_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# OAuth 2.1 Authentication (REQUIRED for production)
# Enable all authentication (MCP + Web API)
# MEM_MESH_AUTH_ENABLED=false

# MCP SSE authentication only (overrides auth_enabled)
# MEM_MESH_MCP_AUTH_ENABLED=false

# Web Dashboard API authentication only (overrides auth_enabled)
# MEM_MESH_WEB_AUTH_ENABLED=false

# Basic Auth for Web Dashboard (browser login)
# MEM_MESH_WEB_BASIC_AUTH_ENABLED=false
# MEM_MESH_ADMIN_USERNAME=admin
# MEM_MESH_ADMIN_PASSWORD=your-secure-password

# OAuth issuer URL (default: http://localhost:8000)
# MEM_MESH_OAUTH_ISSUER=http://localhost:8000

# Token expiration settings (seconds)
# MEM_MESH_ACCESS_TOKEN_TTL=3600       # 1 hour
# MEM_MESH_REFRESH_TOKEN_TTL=604800    # 7 days

# Production settings example (optional)
# MEM_MESH_STORAGE_MODE=direct
# MEM_MESH_DATABASE_PATH=/var/lib/mem-mesh/memories.db
# MEM_MESH_LOG_LEVEL=WARNING
# MEM_MESH_SEARCH_THRESHOLD=0.7
# MEM_MESH_BUSY_TIMEOUT=10000
