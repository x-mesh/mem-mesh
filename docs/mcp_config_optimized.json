{
  "name": "mem-mesh-optimized",
  "version": "2.0",
  "description": "Optimized mem-mesh configuration for minimal noise and better Korean support",

  "search_settings": {
    "default_limit": 5,
    "max_results": 10,
    "min_score_threshold": 0.3,
    "cache_ttl_seconds": 300,
    "aggressive_noise_filter": true,
    "auto_project_detection": true,
    "preferred_language": "ko",

    "noise_filters": {
      "exclude_projects": [
        "^kiro-.*",
        "^test-.*",
        "^tmp-.*",
        "^demo-.*"
      ],
      "exclude_content_patterns": [
        "## Included Rules",
        "I am providing you",
        "^test\\s+test"
      ],
      "min_content_length": 50,
      "max_duplicates": 2
    },

    "preferred_projects": [
      "mem-mesh",
      "mem-mesh-thread-summary-kr",
      "mem-mesh-conversations"
    ],

    "query_expansion": {
      "enabled": true,
      "min_word_length": 2,
      "expand_single_words": true,
      "translation_enabled": true
    },

    "scoring_weights": {
      "text_match": 0.7,
      "vector_similarity": 0.3,
      "project_match_boost": 1.5,
      "category_match_boost": 1.2,
      "recency_boost": 1.1
    }
  },

  "ide_prompts": {
    "system_prompt": "You have access to mem-mesh for context retrieval.\n\nSEARCH RULES:\n1. Always use project filter when available: project='current-project'\n2. Use descriptive phrases, not single words\n3. Limit searches to 5 results\n4. Cache results for 5 minutes\n5. Prefer recent results (last 7 days)\n\nEXAMPLE:\n✅ search('token optimization strategy', project='mem-mesh-optimization', limit=5)\n❌ search('token')",

    "search_template": "search('{query}', project='{project}', limit=5, min_score=0.3)",

    "context_extraction": {
      "auto_detect_project": true,
      "use_git_repo_name": true,
      "fallback_to_folder_name": true,
      "default_project": "general"
    }
  },

  "performance": {
    "embedding_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "batch_size": 100,
    "max_concurrent_searches": 3,
    "connection_pool_size": 5,
    "request_timeout_seconds": 30
  },

  "monitoring": {
    "log_searches": true,
    "track_noise_ratio": true,
    "alert_on_high_noise": true,
    "noise_threshold": 0.5
  }
}