# mem-mesh 환경 설정 예시
# 이 파일을 .env로 복사하고 필요에 따라 수정하세요

# 🆕 새로운 아키텍처 설정 (v2.0)
# 스토리지 모드: direct (기본값) 또는 api
# MEM_MESH_STORAGE_MODE=direct

# API 모드 설정 (storage_mode=api일 때만 사용)
# MEM_MESH_API_BASE_URL=http://localhost:8000

# SQLite 설정
# MEM_MESH_BUSY_TIMEOUT=5000

# 데이터베이스 설정
MEM_MESH_DATABASE_PATH=./data/memories.db

# 로깅 설정
MEM_MESH_LOG_LEVEL=INFO

# 메모리 내용 길이 제한
MEM_MESH_MIN_CONTENT_LENGTH=10
MEM_MESH_MAX_CONTENT_LENGTH=10000

# 임베딩 모델 설정
# MEM_MESH_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEM_MESH_EMBEDDING_MODEL=all-MiniLM-L6-v2
#MEM_MESH_EMBEDDING_MODEL=intfloat/multilingual-e5-small
MEM_MESH_EMBEDDING_DIM=384

# 검색 설정
MEM_MESH_SEARCH_THRESHOLD=0.5

# 서버 설정 (선택사항)
MEM_MESH_SERVER_HOST=127.0.0.1
MEM_MESH_SERVER_PORT=8000

# API 클라이언트 설정
# MEM_MESH_API_TIMEOUT=30.0
# MEM_MESH_API_MAX_RETRIES=3

# 임베딩 재시도 설정
MEM_MESH_MAX_EMBEDDING_RETRIES=3
MEM_MESH_EMBEDDING_RETRY_DELAY=0.1

# 프로덕션 설정 예시 (선택사항)
# MEM_MESH_STORAGE_MODE=direct
# MEM_MESH_DATABASE_PATH=/var/lib/mem-mesh/memories.db
# MEM_MESH_LOG_LEVEL=WARNING
# MEM_MESH_SEARCH_THRESHOLD=0.7
# MEM_MESH_BUSY_TIMEOUT=10000